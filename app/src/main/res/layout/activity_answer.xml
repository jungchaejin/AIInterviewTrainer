<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/soft_gray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/backTextView"
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/main_blue" />

            <TextView
                android:id="@+id/appHomeTextView"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="@string/app_name"
                android:textColor="@color/main_blue"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.18"
                android:text="@string/current_question"
                android:textColor="@color/main_blue"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/questionTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                tools:text="@string/default_question"
                android:textColor="@color/text_black"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="80dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/interviewerImageView"
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_image"
                android:clickable="true"
                android:contentDescription="@string/interviewer_image"
                android:focusable="true"
                android:padding="4dp"
                android:scaleType="centerCrop"
                android:src="@drawable/interviewer"
                app:shapeAppearanceOverlay="@style/CircleImageStyle"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="4dp" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/changeInterviewerImageButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="18dp"
                android:layout_marginEnd="0dp"
                android:background="@drawable/bg_image_add_button"
                android:contentDescription="@string/choose_interviewer_image"
                android:elevation="8dp"
                android:padding="10dp"
                android:src="@drawable/ic_add"
                app:tint="@color/white" />
        </FrameLayout>

        <TextView
            android:id="@+id/listeningTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="-18dp"
            android:background="@drawable/bg_card"
            android:paddingStart="28dp"
            android:paddingTop="12dp"
            android:paddingEnd="28dp"
            android:paddingBottom="12dp"
            android:text="@string/answer_ready"
            android:textColor="@color/text_black"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/answerEditText"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_card"
            android:gravity="top"
            android:hint="@string/answer_hint"
            android:inputType="textMultiLine"
            android:padding="18dp"
            android:textColor="@color/text_black"
            android:textSize="16sp" />

        <Button
            android:id="@+id/speechButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_blue_button"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="@string/start_answer"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/analyzeButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_outline_button"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="@string/analyze_answer"
            android:textColor="@color/main_blue"
            android:textSize="22sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
