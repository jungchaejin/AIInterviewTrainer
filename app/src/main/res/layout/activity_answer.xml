<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFBFD">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 상단바 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/backTextView"
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="←"
                android:textColor="@color/main_blue"
                android:textSize="32sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="AI Interview Coach"
                android:textColor="@color/text_black"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 질문 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.18"
                android:text="CURRENT QUESTION"
                android:textColor="@color/main_blue"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/questionTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="HR 직무에서 가장 중요하다고 생각하는 역량은 무엇인가요?"
                android:textColor="@color/text_black"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 면접관 이미지 -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/interviewerImageView"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="80dp"
            android:background="@drawable/bg_circle_image"
            android:padding="4dp"
            android:scaleType="centerCrop"
            android:src="@drawable/interviewer"
            app:shapeAppearanceOverlay="@style/CircleImageStyle"
            app:strokeColor="#EDEDED"
            app:strokeWidth="4dp" />

        <!-- Listening 표시 -->
        <TextView
            android:id="@+id/listeningTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="-18dp"
            android:background="@drawable/bg_card"
            android:paddingLeft="28dp"
            android:paddingTop="12dp"
            android:paddingRight="28dp"
            android:paddingBottom="12dp"
            android:text="Listening..."
            android:textColor="@color/text_black"
            android:textSize="18sp" />

        <!-- 답변 입력 -->
        <EditText
            android:id="@+id/answerEditText"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_card"
            android:gravity="top"
            android:hint="편안하게 본인의 생각을 말씀해 주세요. 준비가 되시면 '답변하기' 버튼을 눌러 주세요."
            android:inputType="textMultiLine"
            android:padding="18dp"
            android:textColor="@color/text_black"
            android:textSize="16sp" />

        <!-- 답변하기 버튼 -->
        <Button
            android:id="@+id/speechButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_blue_button"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="답변하기"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- 분석하기 버튼 -->
        <Button
            android:id="@+id/analyzeButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_outline_button"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="분석하기"
            android:textColor="@color/main_blue"
            android:textSize="22sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>